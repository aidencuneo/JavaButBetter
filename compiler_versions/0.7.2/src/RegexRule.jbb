use java.util.regex.*;

string find = ""
string replace = ""
string stage = "jbb" // "jbb", "java"
Pattern pattern = null

RegexRule(string find, string replace, string stage):
    this.find = find
    this.replace = replace
    this.stage = stage
    this.pattern = Pattern.compile(find)

bool find(string s):
    return pattern.matcher(s).find()

string apply(string s):
    try
        ret pattern.matcher(s).replaceAll(replace)
    catch Exception e
        ret s
